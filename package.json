{
  "name": "ai-powered-playwright-automation",
  "version": "1.0.0",
  "description": "Hybrid AI-powered Playwright framework for UI, API, and integration testing",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui-tests",
    "test:api": "playwright test tests/api-tests",
    "test:integration": "playwright test tests/integration-tests",
    "test:setup": "playwright test tests/setup",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui-mode": "playwright test --ui",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.3.0",
    "dotenv": "^17.4.0",
    "typescript": "^5.9.2"
  }
}
