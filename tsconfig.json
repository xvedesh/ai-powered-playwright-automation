{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "types": ["node", "@playwright/test"],
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["src/pages/*"],
      "@api/*": ["src/api/*"],
      "@fixtures/*": ["src/fixtures/*"],
      "@utils/*": ["src/utils/*"],
      "@core/*": ["src/core/*"],
      "@config/*": ["src/config/*"],
      "@builders/*": ["test-data/builders/*"],
      "@data/*": ["test-data/*"],
      "@tests/*": ["tests/*"]
    }
  },
  "include": ["src", "tests", "test-data", "playwright.config.ts"]
}
